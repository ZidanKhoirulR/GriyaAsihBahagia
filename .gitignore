##########################
/coverage
/.phpunit.result.cache
phpunit.xml

##########################
# Build & Compiled Files
##########################
npm-debug.log*
yarn-error.log
/.fleet
/.zed

##########################
# Misc
##########################
*.log
*.zip
*.tar.gz
